{
  "name": "out-out",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint . && stylelint \"src/**/*.{css,astro,svelte}\"",
    "lint:eslint": "eslint .",
    "lint:stylelint": "stylelint \"src/**/*.{css,astro,svelte}\"",
    "lint:fix": "eslint . --fix && stylelint \"src/**/*.{css,astro,svelte}\" --fix",
    "format": "prettier --write \"**/*.{js,mjs,ts,tsx,astro,svelte,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,mjs,ts,tsx,astro,svelte,json,css,md}\""
  },
  "dependencies": {
    "@astrojs/svelte": "^8.1.0",
    "@stylexjs/stylex": "0.18.3",
    "astro": "^6.3.1",
    "astro-stylex": "workspace:*",
    "svelte": "^5.55.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylexjs/unplugin": "^0.18.3",
    "eslint": "^10.3.0",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-svelte": "^3.5.1",
    "stylelint": "^17.11.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  }
}
