{
  "name": "out-out",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint . && stylelint \"src/**/*.{css,astro,svelte}\"",
    "lint:fix": "eslint . --fix && stylelint \"src/**/*.{css,astro,svelte}\" --fix",
