# https://editorconfig.org
root = true

[*]
indent_style = tab
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.{json,jsonc}]
indent_style = space
indent_size = 2

[*.{js,mjs,cjs,ts,tsx,jsx}]
indent_style = tab
indent_size = 2

[*.{astro,svelte}]
indent_style = tab
indent_size = 2

[*.{css,scss}]
indent_style = tab
indent_size = 2
